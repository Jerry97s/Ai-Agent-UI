<Window x:Class="AiAgentUi.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:behaviors="clr-namespace:AiAgentUi.Views.Behaviors"
        mc:Ignorable="d"
        Title="AI Agent"
        Width="1040" Height="808"
        MinWidth="920" MinHeight="720"
        Icon="pack://application:,,,/Assets/logo.png"
        WindowStartupLocation="CenterScreen"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Background="{StaticResource ShellBackgroundBrush}"
        AllowDrop="True"
        PreviewDragOver="Root_PreviewDragOver"
        Drop="Root_Drop">
    <Grid Margin="18">
        <Border CornerRadius="18" Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.12" Direction="270" Color="#1E1B4B"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" CornerRadius="18,18,0,0" ClipToBounds="True" Padding="16,14,16,14">
                    <Grid Height="64">
                        <Image Source="pack://application:,,,/Assets/header-accent.png"
                               Stretch="UniformToFill"
                               VerticalAlignment="Center"
                               Opacity="0.38"/>
                        <Border VerticalAlignment="Stretch" Background="#CCFFFFFF"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="14"
                                    BorderBrush="#E2E8F0" BorderThickness="1"
                                    Background="#F8FAFC" Margin="0,0,12,0">
                                <Image Source="pack://application:,,,/Assets/logo.png"
                                       Stretch="Uniform" Margin="5"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="에이전트 채팅" FontWeight="SemiBold" FontSize="15"
                                           Foreground="#0F172A"/>
                                <TextBlock Margin="0,3,0,0" FontSize="11.5" Foreground="#64748B"
                                           Text="기본 127.0.0.1:8787 · AGENT_BASE_URL로 변경 가능"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                <Button x:Name="NewChatButton" Content="새 대화"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding NewConversationCommand}"/>
                                <Button x:Name="ClearButton" Content="기록 삭제"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding ClearHistoryCommand}"/>
                                <Button x:Name="HealthButton" Content="연결 확인"
                                        Style="{StaticResource GhostButton}"
                                        Command="{Binding HealthCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="1" Margin="16,10,16,10" Padding="12" CornerRadius="14"
                        Background="#F8FAFC" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="대화" FontWeight="SemiBold" FontSize="12"
                                   Foreground="#475569" Margin="2,0,0,10"/>
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Custom tab bar (no overlap/clipping) -->
                            <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                          CanContentScroll="False" PanningMode="HorizontalOnly" Margin="0,0,0,10">
                                <ListBox x:Name="ConversationTabs"
                                         ItemsSource="{Binding Conversations}"
                                         SelectedItem="{Binding SelectedConversation}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                         Padding="0">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           Text="{Binding Title}"
                                                           MaxWidth="180"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="{Binding Title}"
                                                           VerticalAlignment="Center"/>
                                                <Button Grid.Column="1"
                                                        Margin="10,0,0,0"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Focusable="False"
                                                        Cursor="Hand"
                                                        Command="{Binding DataContext.TogglePinCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border CornerRadius="6" Padding="4" Background="Transparent">
                                                                <Path x:Name="PinIcon"
                                                                      Width="12" Height="12"
                                                                      Stretch="Uniform"
                                                                      Fill="#94A3B8"
                                                                      Data="M14,2 L10,6 L10,10 L8,12 L12,12 L14,10 L18,10 L22,6 L18,2 Z"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="PinIcon" Property="Fill" Value="#F59E0B"/>
                                                                </Trigger>
                                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                    <Setter TargetName="PinIcon" Property="Fill" Value="#F59E0B"/>
                                                                </DataTrigger>
                                                                <!-- If tab is selected, make pin readable against indigo background -->
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsPinned}" Value="True"/>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter TargetName="PinIcon" Property="Fill" Value="#FFFFFF"/>
                                                                </MultiDataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Margin" Value="0,0,14,0"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <!-- Tag holds MainViewModel for ContextMenu bindings -->
                                            <Setter Property="Tag"
                                                    Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}"/>
                                            <Setter Property="ContextMenu">
                                                <Setter.Value>
                                                    <ContextMenu>
                                                        <MenuItem Header="삭제"
                                                                  Command="{Binding PlacementTarget.Tag.CloseConversationCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                  CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                    </ContextMenu>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Bd"
                                                                CornerRadius="999"
                                                                Padding="14,8"
                                                                Background="#FFFFFF"
                                                                BorderBrush="#E2E8F0"
                                                                BorderThickness="1"
                                                                SnapsToDevicePixels="True">
                                                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Bd" Property="Background" Value="#4F46E5"/>
                                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#4338CA"/>
                                                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                                                <Setter Property="Foreground" Value="#FFFFFF"/>
                                                            </Trigger>
                                                            <MultiTrigger>
                                                                <MultiTrigger.Conditions>
                                                                    <Condition Property="IsMouseOver" Value="True"/>
                                                                    <Condition Property="IsSelected" Value="False"/>
                                                                </MultiTrigger.Conditions>
                                                                <Setter TargetName="Bd" Property="Background" Value="#F1F5F9"/>
                                                            </MultiTrigger>
                                                            <Trigger Property="IsEnabled" Value="False">
                                                                <Setter Property="Opacity" Value="0.5"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                </ListBox>
                            </ScrollViewer>

                            <!-- Messages for selected conversation -->
                            <Border Grid.Row="1" CornerRadius="12" Background="{StaticResource Surface}"
                                    BorderBrush="{StaticResource Border200}" BorderThickness="1">
                                <ListBox x:Name="ChatList" BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="False"
                                         Padding="10"
                                         behaviors:SmoothScrollBehavior.Enabled="True"
                                         behaviors:SmoothScrollBehavior.WheelStep="56"
                                         ItemsSource="{Binding SelectedConversation.Messages}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="0,0,0,6" Padding="12,10" CornerRadius="14" MaxWidth="860"
                                                    Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=ListBox}}">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="ContextMenu">
                                                            <Setter.Value>
                                                                <ContextMenu>
                                                                    <MenuItem Header="삭제"
                                                                              Command="{Binding PlacementTarget.Tag.DeleteMessageCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                                                                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                                                </ContextMenu>
                                                            </Setter.Value>
                                                        </Setter>
                                                        <Setter Property="HorizontalAlignment" Value="Left"/>
                                                        <Setter Property="Background" Value="#EEF2FF"/>
                                                        <Setter Property="BorderBrush" Value="#C7D2FE"/>
                                                        <Setter Property="BorderThickness" Value="1"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsTypingIndicator}" Value="True">
                                                                <Setter Property="ContextMenu" Value="{x:Null}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsUser}" Value="True">
                                                                <Setter Property="Background" Value="#FFFFFF"/>
                                                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                                                <Setter Property="HorizontalAlignment" Value="Right"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock FontWeight="SemiBold" Foreground="#4F46E5"
                                                               FontSize="11.5"
                                                               Text="{Binding Role}" Margin="0,0,0,3"/>
                                                    <Grid>
                                                        <TextBox x:Name="MessageText"
                                                                 Text="{Binding Text}"
                                                                 IsReadOnly="True"
                                                                 IsReadOnlyCaretVisible="False"
                                                                 AcceptsReturn="True"
                                                                 MinLines="1"
                                                                 MaxLines="200"
                                                                 BorderThickness="0"
                                                                 Background="Transparent"
                                                                 Foreground="#0F172A"
                                                                 FontSize="14"
                                                                 TextWrapping="Wrap"
                                                                 Cursor="IBeam"
                                                                 Padding="0"
                                                                 VerticalScrollBarVisibility="Auto"
                                                                 HorizontalScrollBarVisibility="Hidden"/>
                                                        <StackPanel x:Name="TypingDots" Orientation="Horizontal" Visibility="Collapsed">
                                                            <TextBlock Text="●" x:Name="Dot1" Foreground="#4F46E5" Opacity="0.25" FontSize="10" Margin="0,4,6,0"/>
                                                            <TextBlock Text="●" x:Name="Dot2" Foreground="#4F46E5" Opacity="0.25" FontSize="10" Margin="0,4,6,0"/>
                                                            <TextBlock Text="●" x:Name="Dot3" Foreground="#4F46E5" Opacity="0.25" FontSize="10" Margin="0,4,0,0"/>
                                                            <TextBlock Margin="10,0,0,0"
                                                                       VerticalAlignment="Center"
                                                                       Foreground="#64748B"
                                                                       FontSize="12"
                                                                       Text="{Binding DataContext.RemainingSeconds, RelativeSource={RelativeSource AncestorType=Window}, StringFormat={}{0}s}"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding IsTypingIndicator}" Value="True">
                                                    <Setter TargetName="TypingDots" Property="Visibility" Value="Visible"/>
                                                    <Setter TargetName="MessageText" Property="Visibility" Value="Collapsed"/>
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetName="Dot1" Storyboard.TargetProperty="Opacity"
                                                                                 From="0.25" To="1" Duration="0:0:0.35" AutoReverse="True" BeginTime="0:0:0"/>
                                                                <DoubleAnimation Storyboard.TargetName="Dot2" Storyboard.TargetProperty="Opacity"
                                                                                 From="0.25" To="1" Duration="0:0:0.35" AutoReverse="True" BeginTime="0:0:0.12"/>
                                                                <DoubleAnimation Storyboard.TargetName="Dot3" Storyboard.TargetProperty="Opacity"
                                                                                 From="0.25" To="1" Duration="0:0:0.35" AutoReverse="True" BeginTime="0:0:0.24"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>

                <Border Grid.Row="2" Margin="16,0,16,12" Padding="12" CornerRadius="14"
                        Background="White" BorderBrush="#E2E8F0" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" CornerRadius="11" Background="#F8FAFC"
                                BorderBrush="#E2E8F0" BorderThickness="1" Padding="2,1">
                            <TextBox x:Name="MessageBox"
                                     MinHeight="40"
                                     VerticalContentAlignment="Center"
                                     Padding="12,10"
                                     AcceptsReturn="True"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Foreground="#0F172A"
                                     FontSize="14"
                                     CaretBrush="#6366F1"
                                     PreviewKeyDown="MessageBox_PreviewKeyDown"
                                     Text="{Binding SelectedConversation.Draft, UpdateSourceTrigger=PropertyChanged}"/>
                        </Border>
                        <Button x:Name="UploadButton" Grid.Column="1" Content="파일"
                                Margin="10,0,0,0" Style="{StaticResource GhostButton}"
                                Command="{Binding UploadCommand}"/>
                        <Grid Grid.Column="2" Margin="10,0,0,0">
                            <Button x:Name="SendButton" Content="보내기"
                                    Command="{Binding SendCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <Button x:Name="CancelButton"
                                    Command="{Binding CancelCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryActionButton}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Grid Width="14" Height="14" Margin="0,0,8,0">
                                            <Ellipse Stroke="#FFFFFF" StrokeThickness="2" Opacity="0.25"/>
                                            <Path Stroke="#FFFFFF" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                                  Data="M 7,1 A 6,6 0 0 1 13,7">
                                                <Path.RenderTransform>
                                                    <RotateTransform x:Name="SpinnerRotate" CenterX="7" CenterY="7" Angle="0"/>
                                                </Path.RenderTransform>
                                            </Path>
                                            <Grid.Triggers>
                                                <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation Storyboard.TargetName="SpinnerRotate"
                                                                             Storyboard.TargetProperty="Angle"
                                                                             From="0" To="360" Duration="0:0:0.8"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Grid.Triggers>
                                        </Grid>
                                        <TextBlock Text="중지"/>
                                        <TextBlock Margin="8,0,0,0"
                                                   Opacity="0.9"
                                                   Text="{Binding RemainingSeconds, StringFormat={}{0}s}"/>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                        </Grid>
                    </Grid>
                </Border>

                <TextBlock x:Name="StatusText" Grid.Row="3" Margin="20,0,20,14"
                           Foreground="#64748B" FontSize="11.5"
                           HorizontalAlignment="Right"
                           Text="{Binding StatusText}"/>
            </Grid>
        </Border>
    </Grid>
</Window>

