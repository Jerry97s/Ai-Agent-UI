# 에이전트 바인딩 (선택)
# AGENT_HOST=127.0.0.1
# AGENT_PORT=8787

# 데모 모드(에코) 프리픽스 — OPENAI_API_KEY 없을 때만 사용
# AGENT_REPLY_PREFIX=[Python Agent] 

# --- LLM 모드 (OPENAI_API_KEY 가 있으면 활성화) ---
# OpenAI 또는 호환 엔드포인트(Azure OpenAI, 로컬 Ollama 등)
OPENAI_API_KEY=

# 선택: Azure / Ollama(OpenAI 호환). 예: http://localhost:11434/v1
# OPENAI_BASE_URL=

# 모델 ID (프로바이더에 맞게)
# AGENT_CHAT_MODEL=gpt-4o-mini
